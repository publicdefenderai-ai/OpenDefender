# OpenDefender — Required Environment Variables
# Copy this file to .env and fill in real values locally.
# In production (Replit, Railway, etc.), set these in the platform's secret manager.
# NEVER commit .env — it is gitignored.

# ── AI ────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=                  # sk-ant-api03-...

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=                       # postgresql://user:password@host:5432/dbname

# ── Cloudflare Turnstile (CAPTCHA) ───────────────────────────────────────────
TURNSTILE_SECRET_KEY=               # server-side secret from Cloudflare dashboard
TURNSTILE_SITE_KEY=                 # public site key from Cloudflare dashboard

# ── External Legal Data APIs (all optional — features degrade gracefully) ─────
COURTLISTENER_API_TOKEN=            # from courtlistener.com/profile/tokens/
OPENLAWS_API_KEY=
LEGISCAN_API_KEY=
GOVINFO_API_KEY=

# ── Admin ─────────────────────────────────────────────────────────────────────
ADMIN_API_KEY=                      # random high-entropy string for admin endpoints
# ADMIN_DISABLE_AUTH=true           # ONLY set this for local dev; never in production

# ── AI Budget Caps (USD per day) ──────────────────────────────────────────────
AI_DAILY_BUDGET=15
AI_BUDGET_GUIDANCE=10
AI_BUDGET_SUMMARIZER=3
AI_BUDGET_ATTORNEY=5
AI_MAX_REQUEST_COST=0.25
